# Sheriff Home — variables de entorno
# Copiar a .env y completar con valores reales

# ─── AI APIs ───────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Hardware Tapo ─────────────────────────────────────
TAPO_EMAIL=
TAPO_PASSWORD=
TAPO_HUB_IP=192.168.68.62

# ─── Sheriff ───────────────────────────────────────────
SHERIFF_MODE=casa
MOCK_SENSORS=true

# ─── Base de datos ─────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./verisure.db

# ─── Telegram (alertas fallback) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Web Push (VAPID) ──────────────────────────────────
# Generar con: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key); print(v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@sheriff.home

# ─── App ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:5173
